# OAuth 2.1 Configuration
SIMONE_OAUTH_ISSUER=https://accounts.google.com
SIMONE_OAUTH_AUDIENCE=simone-mcp
SIMONE_OAUTH_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
SIMONE_AUTH_REQUIRED=false
SIMONE_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://a2a.delqhi.com

# Database Connections
QDRANT_URL=http://qdrant:6333
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_prod

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=simone-mcp

# Application
LOG_LEVEL=INFO
